# Identifiants TUM (Shibboleth SSO)
TUM_USERNAME=votre_identifiant_tum (ex: ab12cde)
TUM_PASSWORD=votre_mot_de_passe

# AWS Credentials (pour Amazon Bedrock)
# Assurez-vous que l'utilisateur IAM associé a les permissions `bedrock:InvokeModel`
AWS_ACCESS_KEY_ID=votre_aws_access_key
AWS_SECRET_ACCESS_KEY=votre_aws_secret_key
AWS_DEFAULT_REGION=us-east-1  # ou la région où vous avez accès aux modèles Bedrock (ex: us-west-2, eu-central-1)

# Options de configuration de l'Agent
# Le modèle recommandé sur Bedrock pour des tâches de navigation web est Claude 3 Sonnet ou Claude 3 Opus
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
